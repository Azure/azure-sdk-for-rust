{
  "displayNames": {},
  "matrix": {
    "Agent": {
      "ubuntu": {
        "OSVmImage": "env:LINUXVMIMAGE",
        "Pool": "env:LINUXPOOL"
      },
      "windows": {
        "OSVmImage": "env:WINDOWSVMIMAGE",
        "Pool": "env:WINDOWSPOOL"
      },
      "macos": {
        "OSVmImage": "env:MACVMIMAGEM1",
        "Pool": "env:MACPOOL"
      }
    },
    "RustToolchainName": [
      "stable",
      "msrv",
      "nightly"
    ]
  },
  "exclude": [
    {
      "Pool": "env:MACVMIMAGEM1",
      "RustToolchainName": "msrv"
    },
    {
      "Pool": "env:MACVMIMAGEM1",
      "RustToolchainName": "nightly"
    },
    {
      "Pool": "env:WINDOWSVMIMAGE",
      "RustToolchainName": "msrv"
    },
    {
      "Pool": "env:WINDOWSVMIMAGE",
      "RustToolchainName": "nightly"
    }
  ]
}