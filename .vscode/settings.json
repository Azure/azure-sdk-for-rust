{
  "azure-pipelines.1ESPipelineTemplatesSchemaFile": true,
  "cmake.ignoreCMakeListsMissing": true,
  "cSpell.enabled": true,
  "editor.formatOnSave": true,
  "files.associations": {
    "CODEOWNERS": "ignore"
  },
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".github/instructions/git-commit.instructions.md"
    }
  ],
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    {
      "file": ".github/instructions/github-pullrequest.instructions.md"
    }
  ],
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.linkedProjects": [
    "Cargo.toml",
    "eng/tools/Cargo.toml",
    "eng/scripts/update-cratenames.rs",
    "eng/scripts/update-pathversions.rs",
    "eng/scripts/verify-dependencies.rs",
    "eng/scripts/verify-keywords.rs",
  ],
  "yaml.format.printWidth": 240,
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell",
  },
}
