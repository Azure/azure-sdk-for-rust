{
  "version": "1.0",
  "primary_sdk": "rust",
  "primary_repo": {
    "owner": "Azure",
    "name": "azure-sdk-for-rust",
    "url": "https://github.com/Azure/azure-sdk-for-rust",
    "default_branch": "main",
    "previews_branch": "release/azure_data_cosmos-previews"
  },
  "branch_name": "tvaron3/gateway-2.0-impl",
  "pr_convention": "fork",
  "fork": {
    "owner": "tvaron3",
    "name": "azure-sdk-for-rust",
    "url": "https://github.com/tvaron3/azure-sdk-for-rust"
  },
  "ci_system": "ado",
  "workflow_files": [
    "sdk/cosmos/ci.yml"
  ],
  "commands": {
    "lint": "cargo clippy -p azure_data_cosmos_driver -p azure_data_cosmos --all-targets --all-features",
    "format": "cargo fmt -p azure_data_cosmos_driver -p azure_data_cosmos -- --check",
    "test": "cargo test -p azure_data_cosmos_driver -p azure_data_cosmos --all-features",
    "build": "cargo build -p azure_data_cosmos_driver -p azure_data_cosmos --all-features"
  },
  "contributing_md_path": "CONTRIBUTING.md",
  "code_owners_path": ".github/CODEOWNERS",
  "style_guide_paths": ["rustfmt.toml", ".editorconfig"]
}
